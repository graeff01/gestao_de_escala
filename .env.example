# Firebase config — copy this file to ".env" and fill in the real values.
# These come from the Firebase Console:
#   1. Open https://console.firebase.google.com
#   2. Select your project
#   3. Project Settings (gear icon) -> "Your apps" -> Web app
#   4. Copy the values from the firebaseConfig snippet
#
# IMPORTANT: never commit a real .env file. The .gitignore already blocks it.

VITE_FIREBASE_API_KEY=AIzaSy...your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef0123456789
